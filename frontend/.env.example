# AI provider selection:
# - auto: use DeepSeek when DEEPSEEK_API_KEY exists, then fall back to Ollama, then scenario script
# - deepseek: prefer DeepSeek API, then fall back to Ollama, then scenario script
# - ollama: use local Ollama, then scenario script
AI_PROVIDER=auto

# DeepSeek API mode. Put the real key only in frontend/.env.local, never commit it.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_DIALOG=deepseek-v4-flash
DEEPSEEK_MODEL_REPORT=deepseek-v4-pro

# Local Ollama mode.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2:7b
