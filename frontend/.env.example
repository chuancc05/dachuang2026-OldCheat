# AI provider selection:
# - auto: use DeepSeek when DEEPSEEK_API_KEY exists, then fall back to Ollama, then scenario script
# - deepseek: prefer DeepSeek API, then fall back to Ollama, then scenario script
# - ollama: use local Ollama, then scenario script
AI_PROVIDER=auto

# DeepSeek API mode. Put the real key only in frontend/.env.local, never commit it.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Optional fallback for hosting platforms that block sk-* values in plain env vars.
DEEPSEEK_API_KEY_B64=base64_encoded_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_DIALOG=deepseek-v4-flash
DEEPSEEK_MODEL_REPORT=deepseek-v4-pro

# Local Ollama mode.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2:7b

# Hybrid RAG retrieval. Keep enabled for normal demos.
RAG_ENABLED=true
RAG_TOP_K=5
RAG_USE_VECTOR=true
RAG_EMBED_PROVIDER=ollama
RAG_EMBED_MODEL=bge-m3
RAG_EMBED_DIMENSIONS=1024

# Online vector RAG for Netlify or other cloud demos.
# Use DashScope Qwen3-Embedding by setting:
# RAG_EMBED_PROVIDER=dashscope
# RAG_EMBED_MODEL=text-embedding-v4
# RAG_EMBED_BATCH_SIZE=10
# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# DASHSCOPE_API_KEY_B64=base64_encoded_dashscope_api_key_here
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Realtime voice call mode.
# Start with: pnpm.cmd run voice:gateway
# Browser connects to this local gateway; the gateway keeps DASHSCOPE_API_KEY server-side.
NEXT_PUBLIC_VOICE_GATEWAY_URL=ws://127.0.0.1:8787/voice
VOICE_GATEWAY_PORT=8787
DASHSCOPE_ASR_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime?model=qwen3-asr-flash-realtime
DASHSCOPE_TTS_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime?model=qwen3-tts-flash-realtime
# Optional style-control model. If your account/region can synthesize with it, the gateway will pass
# leading style cues such as "（语气严肃）" through instructions instead of speaking them.
# DASHSCOPE_TTS_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime?model=qwen3-tts-instruct-flash-realtime
# Default fallback voice. The realtime training UI can override this per scenario.
DASHSCOPE_TTS_VOICE=Cherry
# Optional if your Alibaba Cloud workspace later requires it.
# DASHSCOPE_WORKSPACE_ID=your_workspace_id_here

