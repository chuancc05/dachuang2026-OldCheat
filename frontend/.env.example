# AI provider selection:
# - auto: use DeepSeek when DEEPSEEK_API_KEY exists, then fall back to Ollama, then scenario script
# - deepseek: prefer DeepSeek API, then fall back to Ollama, then scenario script
# - ollama: use local Ollama, then scenario script
AI_PROVIDER=auto

# DeepSeek API mode. Put the real key only in frontend/.env.local, never commit it.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Optional fallback for hosting platforms that block sk-* values in plain env vars.
DEEPSEEK_API_KEY_B64=base64_encoded_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_DIALOG=deepseek-v4-flash
DEEPSEEK_MODEL_REPORT=deepseek-v4-pro

# Local Ollama mode.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2:7b

# Hybrid RAG retrieval. Keep enabled for normal demos.
RAG_ENABLED=true
RAG_TOP_K=5
RAG_USE_VECTOR=true
RAG_EMBED_PROVIDER=ollama
RAG_EMBED_MODEL=bge-m3
RAG_EMBED_DIMENSIONS=1024

# Online vector RAG for Netlify or other cloud demos.
# Use DashScope Qwen3-Embedding by setting:
# RAG_EMBED_PROVIDER=dashscope
# RAG_EMBED_MODEL=text-embedding-v4
# RAG_EMBED_BATCH_SIZE=10
# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# DASHSCOPE_API_KEY_B64=base64_encoded_dashscope_api_key_here
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

